---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import ShareButtons from '../components/ShareButtons.astro';
import { SITE_TITLE } from '../consts';

type Props = CollectionEntry<'blog'>['data'] & {
	postId?: string;
	isArticle?: boolean;
};

const { title, description, pubDate, updatedDate, heroImage, faq, tags, postId, isArticle = true } =
	Astro.props;

const pageURL = new URL(Astro.url.pathname, Astro.site).href;

const articleLd = isArticle && {
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: title,
	description: description,
	datePublished: pubDate.toISOString(),
	...(updatedDate && { dateModified: updatedDate.toISOString() }),
	mainEntityOfPage: pageURL,
	...(heroImage && { image: new URL(heroImage.src, Astro.site).href }),
	author: { '@type': 'Organization', name: '생활정보노트 편집팀' },
	publisher: {
		'@type': 'Organization',
		name: SITE_TITLE,
		logo: { '@type': 'ImageObject', url: new URL('/favicon.svg', Astro.site).href },
	},
};

const breadcrumbLd = isArticle && {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: '홈', item: Astro.site?.href },
		{ '@type': 'ListItem', position: 2, name: '전체 글', item: new URL('/blog/', Astro.site).href },
		{ '@type': 'ListItem', position: 3, name: title },
	],
};

const faqLd = isArticle &&
	faq &&
	faq.length > 0 && {
		'@context': 'https://schema.org',
		'@type': 'FAQPage',
		mainEntity: faq.map((f) => ({
			'@type': 'Question',
			name: f.question,
			acceptedAnswer: { '@type': 'Answer', text: f.answer },
		})),
	};

const related = postId
	? (await getCollection('blog'))
			.filter((p) => p.id !== postId)
			.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
			.slice(0, 3)
	: [];
---

<html lang="ko">
	<head>
		<BaseHead
			title={title}
			description={description}
			image={heroImage}
			type={isArticle ? 'article' : 'website'}
			pubDate={pubDate}
			updatedDate={updatedDate}
		/>
		{articleLd && <script type="application/ld+json" set:html={JSON.stringify(articleLd)} />}
		{breadcrumbLd && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />}
		{faqLd && <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />}
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 760px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 2.2em 2.5em;
				color: rgb(var(--gray-dark));
				background: var(--card-bg);
				border: 1px solid rgb(var(--gray-light));
				border-radius: var(--radius);
				box-shadow: var(--box-shadow);
			}
			.title {
				margin-bottom: 1.5em;
				padding-bottom: 1.5em;
				text-align: center;
				line-height: 1.3;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.title h1 {
				margin: 0.4em 0 0.5em;
				font-size: 1.75em;
			}
			.meta-row {
				display: flex;
				align-items: center;
				justify-content: center;
				gap: 0.8em;
			}
			.date {
				color: rgb(var(--gray));
				font-size: 0.85em;
			}
			.author {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 0.82em;
			}
			.last-updated-on {
				font-style: italic;
				font-size: 0.85em;
				color: rgb(var(--gray));
				margin-top: 0.3em;
			}
			@media (max-width: 720px) {
				.prose {
					padding: 1.5em 1.2em;
				}
				.title h1 {
					font-size: 1.4em;
				}
			}
			.related {
				margin-top: 3em;
				padding: 1.5em;
				background: rgba(var(--gray-light), 40%);
				border-radius: 12px;
			}
			.related h2 {
				font-size: 1.2em;
				margin-bottom: 0.8em;
			}
			.related ul {
				margin: 0;
				padding-left: 1.2em;
			}
			.related li {
				margin-bottom: 0.4em;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt={title} />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="meta-row">
							{
							isArticle && tags?.[0] && (
								<a class="tag-chip" href={`/category/${encodeURIComponent(tags[0])}/`}>
									{tags[0]}
								</a>
							)
						}
							<span class="date">
								<FormattedDate date={pubDate} />
							</span>
						</div>
						<h1>{title}</h1>
						{isArticle && <p class="author">생활정보노트 편집팀</p>}
						{
							updatedDate && (
								<div class="last-updated-on">
									최종 수정: <FormattedDate date={updatedDate} />
								</div>
							)
						}
					</div>
					<slot />
					{isArticle && <ShareButtons title={title} />}
					{
						related.length > 0 && (
							<aside class="related">
								<h2>함께 보면 좋은 글</h2>
								<ul>
									{related.map((p) => (
										<li>
											<a href={`/blog/${p.id}/`}>{p.data.title}</a>
										</li>
									))}
								</ul>
							</aside>
						)
					}
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
